name: 🚀 CrazyGames Slide Rush Bot

on:
  workflow_dispatch: # Manually trigger from the GitHub Actions tab

jobs:
  run-bot:
    runs-on: ubuntu-latest
    
    steps:
      - name: 🐍 Set up Python
        uses: actions/setup-python@v4
        with:
          python-version: '3.10'

      - name: 📦 Install Dependencies
        run: |
          pip install selenium

      - name: 📝 Generate Bot Script
        run: |
          cat << 'EOF' > bot.py
          import time
          import random
          import sys
          from selenium import webdriver
          from selenium.webdriver.chrome.options import Options
          from selenium.webdriver.common.by import By
          from selenium.webdriver.common.keys import Keys
          from selenium.webdriver.common.action_chains import ActionChains

          def setup_driver():
              options = Options()
              options.add_argument("--headless=new")
              options.add_argument("--window-size=1920,1080")
              options.add_argument("--no-sandbox")
              options.add_argument("--disable-dev-shm-usage")
              options.add_argument("--mute-audio")
              options.add_argument("--disable-blink-features=AutomationControlled")
              return webdriver.Chrome(options=options)

          def find_game_frame(driver):
              """Locates the iframe containing the actual game on CrazyGames."""
              try:
                  # CrazyGames usually wraps the game in an iframe with ID 'game-iframe'
                  frame = driver.find_element(By.ID, "game-iframe")
                  driver.switch_to.frame(frame)
                  
                  # Sometimes there is a nested iframe inside the first one
                  nested_iframes = driver.find_elements(By.TAG_NAME, "iframe")
                  if len(nested_iframes) > 0:
                      driver.switch_to.frame(nested_iframes[0])
                      
                  print("✅ Successfully connected to the Game Canvas!", flush=True)
                  return True
              except Exception as e:
                  print("⚠️ Standard frame not found, attempting fallback search...", flush=True)
                  iframes = driver.find_elements(By.TAG_NAME, "iframe")
                  for i, frame in enumerate(iframes):
                      # Look for a reasonably sized iframe (ignores tiny ad frames)
                      if frame.size['width'] > 300 and frame.size['height'] > 300:
                          driver.switch_to.frame(frame)
                          print(f"✅ Switched to large fallback iframe ({i})", flush=True)
                          return True
              return False

          def click_center(driver):
              """Clicks the center of the game canvas to clear menus/next level buttons."""
              try:
                  canvas = driver.find_element(By.TAG_NAME, 'canvas')
                  ActionChains(driver).move_to_element(canvas).click().perform()
              except:
                  # If canvas not found, click center of current frame
                  try:
                      body = driver.find_element(By.TAG_NAME, 'body')
                      ActionChains(driver).move_to_element(body).click().perform()
                  except:
                      pass

          def main():
              driver = setup_driver()
              print("⏳ Loading CrazyGames: Slide Rush...", flush=True)
              
              # Target URL for Slide Rush
              driver.get("https://www.crazygames.com/game/slide-rush?bypassCache=4482f")
              
              # Give the site generous time to load ads and iframes
              time.sleep(15)
              driver.save_screenshot("screenshot_01_loaded.png")
              print("📸 Saved site loaded screenshot.", flush=True)

              if not find_game_frame(driver):
                  print("❌ Failed to find game iframe. Exiting.", flush=True)
                  driver.quit()
                  return

              time.sleep(5)
              
              # Attempt to click to focus the game and start
              click_center(driver)
              time.sleep(2)
              ActionChains(driver).send_keys(Keys.SPACE).perform()
              
              driver.save_screenshot("screenshot_02_playing.png")
              print("📸 Saved active gameplay screenshot.", flush=True)

              print("🤖 Bot Active. Starting auto-slider...", flush=True)
              
              actions = ActionChains(driver)
              directions = [Keys.ARROW_UP, Keys.ARROW_DOWN, Keys.ARROW_LEFT, Keys.ARROW_RIGHT]
              
              loop_count = 0

              # Infinite gameplay loop
              while True:
                  # Randomly slide in a direction to play the game
                  move = random.choice(directions)
                  actions.send_keys(move).perform()
                  
                  loop_count += 1
                  
                  # Every ~50 moves, try to click the screen to bypass "Next Level" / "Game Over" menus
                  if loop_count % 50 == 0:
                      print(f"🔄 Made {loop_count} slides. Clicking center to clear popups...", flush=True)
                      click_center(driver)
                      actions.send_keys(Keys.SPACE).perform() # Alternative menu progression

                  # Wait a fraction of a second before sliding again (adjust if game requires faster/slower inputs)
                  time.sleep(0.3)

          if __name__ == "__main__":
              main()
          EOF

      - name: 🤖 Run Bot Background Task
        run: |
          # Runs in the background and logs to bot.log
          nohup python bot.py > bot.log 2>&1 &

      - name: ⏱️ Wait for Bot Initialization
        # Allow 45 seconds for the bot to load the site, traverse the iframes, and take pictures
        run: sleep 45

      - name: 📸 Upload Proof Screenshots & Logs
        uses: actions/upload-artifact@v4
        with:
          name: bot-proof-artifacts
          path: |
            *.png
            bot.log

      - name: ♾️ Keep Alive
        # 21600 seconds = 6 hours. The GitHub VM will shut down automatically when the limit is reached.
        run: sleep 21600
