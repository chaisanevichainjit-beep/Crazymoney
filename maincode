name: 🚀 CrazyGames 6-Hour Bot

on:
  workflow_dispatch: # Manually trigger from GitHub Actions tab

jobs:
  run-bot:
    runs-on: ubuntu-latest
    timeout-minutes: 360 # Forces the job to run up to the 6-hour GitHub limit
    
    steps:
      - name: 🐍 Set up Python
        uses: actions/setup-python@v4
        with:
          python-version: '3.10'

      - name: 📦 Install Dependencies
        run: pip install selenium

      - name: 📝 Generate Bot Script
        run: |
          cat << 'EOF' > bot.py
          import time
          import sys
          import random
          from selenium import webdriver
          from selenium.webdriver.chrome.options import Options
          from selenium.webdriver.common.by import By
          from selenium.webdriver.common.keys import Keys
          from selenium.webdriver.common.action_chains import ActionChains

          def setup_driver():
              options = Options()
              options.add_argument("--headless=new")
              options.add_argument("--window-size=1280,720")
              options.add_argument("--mute-audio")
              options.add_argument("--disable-blink-features=AutomationControlled")
              options.add_argument("--no-sandbox")
              options.add_argument("--disable-dev-shm-usage")
              
              print("🚀 Launching Google Chrome...", flush=True)
              return webdriver.Chrome(options=options)

          def find_game_frame(driver):
              try:
                  frame = driver.find_element(By.ID, "game-iframe")
                  driver.switch_to.frame(frame)
                  nested_iframes = driver.find_elements(By.TAG_NAME, "iframe")
                  if len(nested_iframes) > 0:
                      driver.switch_to.frame(nested_iframes[0])
                  print("✅ Successfully connected to the Game Canvas!", flush=True)
                  return True
              except Exception:
                  iframes = driver.find_elements(By.TAG_NAME, "iframe")
                  for i, frame in enumerate(iframes):
                      if frame.size['width'] > 300 and frame.size['height'] > 300:
                          driver.switch_to.frame(frame)
                          print(f"✅ Switched to fallback iframe ({i})", flush=True)
                          return True
              return False

          def is_button_visible(driver, button_id):
              script = f"""
              var btn = document.getElementById('{button_id}');
              return (btn && btn.offsetParent !== null && !btn.closest('.hidden'));
              """
              try:
                  return driver.execute_script(script)
              except:
                  return False

          def click_html_button(driver, button_id):
              script = f"document.getElementById('{button_id}').click();"
              try:
                  driver.execute_script(script)
              except:
                  pass

          def spam_virtual_clicks_and_keys(driver):
              """Sends proper clicks (Down AND Up) and arrow keys to ensure the game is played."""
              # 1. Javascript Canvas Clicks
              script = """
              var canvas = document.querySelector('canvas');
              if (canvas && canvas.offsetParent !== null) {
                  var rect = canvas.getBoundingClientRect();
                  // Send random clicks across the game board
                  for (let i = 0; i < 3; i++) {
                      var x = rect.left + (Math.random() * rect.width);
                      var y = rect.top + (Math.random() * rect.height);
                      
                      // MUST have both down and up for WebGL to register a click
                      var down = new PointerEvent('pointerdown', {clientX: x, clientY: y, bubbles: true});
                      var up = new PointerEvent('pointerup', {clientX: x, clientY: y, bubbles: true});
                      
                      canvas.dispatchEvent(down);
                      canvas.dispatchEvent(up);
                  }
              }
              """
              try:
                  driver.execute_script(script)
                  
                  # 2. Also send Arrow Keys & Spacebar (Most common for Slide Rush)
                  actions = ActionChains(driver)
                  directions = [Keys.ARROW_UP, Keys.ARROW_DOWN, Keys.ARROW_LEFT, Keys.ARROW_RIGHT, Keys.SPACE]
                  actions.send_keys(random.choice(directions)).perform()
              except:
                  pass

          def wake_up_crazygames(driver):
              try:
                  # Click dead center of the screen to focus the canvas
                  canvas = driver.find_element(By.TAG_NAME, 'canvas')
                  ActionChains(driver).move_to_element(canvas).click().perform()
              except:
                  try:
                      body = driver.find_element(By.TAG_NAME, 'body')
                      ActionChains(driver).move_to_element(body).click().perform()
                  except:
                      pass

          def main():
              driver = setup_driver()
              print("⏳ Loading CrazyGames: Slide Rush...", flush=True)
              driver.get("https://www.crazygames.com/game/slide-rush?bypassCache=4482f")
              
              print("⏳ Waiting 15 seconds for site to load...", flush=True)
              time.sleep(15)

              if not find_game_frame(driver):
                  print("❌ Failed to find game iframe. Exiting.", flush=True)
                  driver.quit()
                  return

              print("🖱️ Waking up the game frame...", flush=True)
              wake_up_crazygames(driver)
              time.sleep(2)
              
              print("\n🤖 BOT ACTIVE: Auto-playing has started!", flush=True)
              print("⏱️ The bot will now run continuously for up to 6 hours.\n", flush=True)
              
              loop_count = 0
              try:
                  # Infinite Loop - Keeps the GitHub Action alive for 6 hours
                  while True:
                      loop_count += 1
                      
                      # Occasional status update so you know it hasn't frozen
                      if loop_count % 300 == 0:
                          print(f"🔄 Bot is still running... ({loop_count} loops completed)", flush=True)

                      # 1. Check for HTML menus (Just in case the game uses them)
                      if is_button_visible(driver, "btn-infinite"):
                          print("⏳ Main menu detected! Clicking Survival Mode.", flush=True)
                          click_html_button(driver, "btn-infinite")
                          wake_up_crazygames(driver) # Re-focus canvas
                          time.sleep(2)

                      elif is_button_visible(driver, "next-level-btn"):
                          print("⏭️ Level Ended! Clicking Next Level.", flush=True)
                          click_html_button(driver, "next-level-btn")
                          wake_up_crazygames(driver) # Re-focus canvas
                          time.sleep(2)

                      # 2. Play the game! (Clicks + Keys)
                      else:
                          spam_virtual_clicks_and_keys(driver)
                          
                          # Periodically click the center to clear hidden "Next Level" WebGL menus
                          if loop_count % 50 == 0:
                              wake_up_crazygames(driver)

                      # Delay so we don't crash the browser
                      time.sleep(0.2)
                      
              except Exception as e:
                  print(f"\n❌ An error occurred: {e}", flush=True)
                  driver.quit()

          if __name__ == "__main__":
              main()
          EOF

      - name: 🤖 Run Bot (Live Output)
        # Because we run this directly (no nohup), the GitHub Action step will 
        # stay open, running your loop, and printing live logs for the full 6 hours.
        run: python bot.py
