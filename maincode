name: 🚀 CrazyGames Slide Rush Bot

on:
  workflow_dispatch: # Manually trigger from the GitHub Actions tab

jobs:
  run-bot:
    runs-on: ubuntu-latest
    
    steps:
      - name: 🐍 Set up Python
        uses: actions/setup-python@v4
        with:
          python-version: '3.10'

      - name: 📦 Install Dependencies
        run: |
          pip install selenium

      - name: 📝 Generate Bot Script
        run: |
          cat << 'EOF' > bot.py
          import time
          import sys
          import random
          from selenium import webdriver
          from selenium.webdriver.chrome.options import Options
          from selenium.webdriver.common.by import By

          def setup_driver():
              options = Options()
              options.add_argument("--headless=new") # Required for GitHub Actions
              options.add_argument("--window-size=1280,720")
              options.add_argument("--mute-audio")
              options.add_argument("--disable-blink-features=AutomationControlled")
              options.add_argument("--no-sandbox") # Required for Linux Runner
              options.add_argument("--disable-dev-shm-usage") # Required for Linux Runner
              
              print("🚀 Launching Google Chrome...", flush=True)
              return webdriver.Chrome(options=options)

          def find_game_frame(driver):
              """Locates the iframe containing the actual game on CrazyGames."""
              try:
                  frame = driver.find_element(By.ID, "game-iframe")
                  driver.switch_to.frame(frame)
                  nested_iframes = driver.find_elements(By.TAG_NAME, "iframe")
                  if len(nested_iframes) > 0:
                      driver.switch_to.frame(nested_iframes[0])
                  print("✅ Successfully connected to the Game Canvas!", flush=True)
                  return True
              except Exception:
                  iframes = driver.find_elements(By.TAG_NAME, "iframe")
                  for i, frame in enumerate(iframes):
                      if frame.size['width'] > 300 and frame.size['height'] > 300:
                          driver.switch_to.frame(frame)
                          print(f"✅ Switched to fallback iframe ({i})", flush=True)
                          return True
              return False

          def is_button_visible(driver, button_id):
              """Checks if an HTML button exists and is currently visible on the screen."""
              script = f"""
              var btn = document.getElementById('{button_id}');
              return (btn && btn.offsetParent !== null && !btn.closest('.hidden'));
              """
              try:
                  return driver.execute_script(script)
              except:
                  return False

          def click_html_button(driver, button_id):
              """Executes a click on the specified HTML button."""
              script = f"document.getElementById('{button_id}').click();"
              try:
                  driver.execute_script(script)
              except:
                  pass

          def spam_virtual_clicks(driver):
              """Injects JavaScript to rapidly simulate real mouse clicks on the canvas."""
              script = """
              var canvas = document.querySelector('canvas');
              if (canvas && canvas.offsetParent !== null) {
                  var rect = canvas.getBoundingClientRect();
                  // Send 10 random clicks across the game board instantly
                  for (let i = 0; i < 10; i++) {
                      var x = Math.random() * rect.width;
                      var y = Math.random() * rect.height;
                      var ev = new PointerEvent('pointerdown', {
                          clientX: rect.left + x,
                          clientY: rect.top + y,
                          bubbles: true,
                          cancelable: true
                      });
                      canvas.dispatchEvent(ev);
                  }
              }
              """
              try:
                  driver.execute_script(script)
              except:
                  pass

          def wake_up_crazygames(driver):
              """Sometimes CrazyGames has an invisible overlay that needs one real click."""
              try:
                  body = driver.find_element(By.TAG_NAME, 'body')
                  webdriver.ActionChains(driver).move_to_element(body).click().perform()
              except:
                  pass

          def main():
              driver = setup_driver()
              print("⏳ Loading CrazyGames: Slide Rush...", flush=True)
              driver.get("https://www.crazygames.com/game/slide-rush?bypassCache=4482f")
              
              print("⏳ Waiting 10 seconds for site to load...", flush=True)
              time.sleep(10)
              driver.save_screenshot("01_site_loaded.png") # Proof image

              if not find_game_frame(driver):
                  print("❌ Failed to find game iframe. Exiting.", flush=True)
                  driver.quit()
                  return

              print("🖱️ Waking up the game frame...", flush=True)
              wake_up_crazygames(driver)
              time.sleep(1)
              
              print("\n🤖 BOT ACTIVE: Auto-playing has started!", flush=True)
              print("🎯 Target Mode: Survival Mode (Always)\n", flush=True)
              
              loop_counter = 0
              try:
                  while True:
                      # 1. Main Menu check
                      if is_button_visible(driver, "btn-infinite"):
                          print("⏳ Main menu detected! Waiting 1.5 seconds to look human...", flush=True)
                          time.sleep(1.5)
                          click_html_button(driver, "btn-infinite")
                          print("🎮 Clicked: Survival Mode!", flush=True)
                          time.sleep(1) # Let the game load
                          driver.save_screenshot("02_gameplay_started.png")

                      # 2. Next Level / Game Over check
                      elif is_button_visible(driver, "next-level-btn"):
                          print("⏳ Level Ended! Waiting 2 seconds to look human...", flush=True)
                          time.sleep(2.0)
                          click_html_button(driver, "next-level-btn")
                          print("⏭️ Clicked: Next Level / Continue!", flush=True)
                          time.sleep(1) # Let the next level load

                      # 3. If no menus are open, play the game!
                      else:
                          spam_virtual_clicks(driver)

                      # Wait a fraction of a second before looping
                      time.sleep(0.1)
                      
                      loop_counter += 1
                      # Take a screenshot every ~30 seconds of gameplay to prove it's still running
                      if loop_counter % 300 == 0:
                          driver.save_screenshot("03_active_gameplay_proof.png")
                      
              except KeyboardInterrupt:
                  print("\n🛑 Bot stopped manually. Closing browser...", flush=True)
                  driver.quit()
                  sys.exit()
              except Exception as e:
                  print(f"\n❌ An error occurred: {e}", flush=True)
                  driver.quit()

          if __name__ == "__main__":
              main()
          EOF

      - name: 🤖 Run Bot Background Task
        run: |
          # Runs in the background and logs to bot.log
          nohup python bot.py > bot.log 2>&1 &

      - name: ⏱️ Wait for Bot Initialization
        # Allow 45 seconds for the bot to load the site, navigate menus, and take pictures
        run: sleep 45

      - name: 📸 Upload Proof Screenshots & Logs
        uses: actions/upload-artifact@v4
        with:
          name: bot-proof-artifacts
          path: |
            *.png
            bot.log

      - name: ♾️ Keep Alive
        # 21600 seconds = 6 hours. The GitHub VM will shut down automatically when the limit is reached.
        run: sleep 21600
